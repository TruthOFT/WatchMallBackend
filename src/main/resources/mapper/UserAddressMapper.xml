<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.watch.watch_mall.mapper.UserAddressMapper">

    <resultMap id="BaseResultMap" type="com.watch.watch_mall.model.entity.UserAddress">
        <id property="id" column="id"/>
        <result property="userId" column="userId"/>
        <result property="receiverName" column="receiverName"/>
        <result property="receiverPhone" column="receiverPhone"/>
        <result property="province" column="province"/>
        <result property="city" column="city"/>
        <result property="district" column="district"/>
        <result property="detailAddress" column="detailAddress"/>
        <result property="postalCode" column="postalCode"/>
        <result property="isDefault" column="isDefault"/>
        <result property="createTime" column="createTime"/>
        <result property="updateTime" column="updateTime"/>
        <result property="isDelete" column="isDelete"/>
    </resultMap>

    <resultMap id="UserAddressVOResultMap" type="com.watch.watch_mall.model.vo.UserAddressVO">
        <id property="id" column="id"/>
        <result property="receiverName" column="receiverName"/>
        <result property="receiverPhone" column="receiverPhone"/>
        <result property="province" column="province"/>
        <result property="city" column="city"/>
        <result property="district" column="district"/>
        <result property="detailAddress" column="detailAddress"/>
        <result property="postalCode" column="postalCode"/>
        <result property="isDefault" column="isDefault"/>
        <result property="createTime" column="createTime"/>
        <result property="updateTime" column="updateTime"/>
    </resultMap>

    <sql id="BaseColumnList">
        id, userId, receiverName, receiverPhone, province, city, district,
        detailAddress, postalCode, isDefault, createTime, updateTime, isDelete
    </sql>

    <select id="listMyAddress" resultMap="UserAddressVOResultMap">
        select
            id,
            receiverName,
            receiverPhone,
            province,
            city,
            district,
            detailAddress,
            postalCode,
            isDefault,
            createTime,
            updateTime
        from user_address
        where userId = #{userId}
          and isDelete = 0
        order by isDefault desc, updateTime desc, id desc
    </select>

    <select id="selectMyAddressDetail" resultMap="UserAddressVOResultMap">
        select
            id,
            receiverName,
            receiverPhone,
            province,
            city,
            district,
            detailAddress,
            postalCode,
            isDefault,
            createTime,
            updateTime
        from user_address
        where userId = #{userId}
          and id = #{id}
          and isDelete = 0
        limit 1
    </select>

    <select id="selectOwnedAddress" resultMap="BaseResultMap">
        select
            <include refid="BaseColumnList"/>
        from user_address
        where userId = #{userId}
          and id = #{id}
          and isDelete = 0
        limit 1
    </select>

    <update id="clearDefaultByUserId">
        update user_address
        set isDefault = 0
        where userId = #{userId}
          and isDelete = 0
          and isDefault = 1
    </update>

    <select id="selectNextDefaultCandidate" resultMap="BaseResultMap">
        select
            <include refid="BaseColumnList"/>
        from user_address
        where userId = #{userId}
          and isDelete = 0
        order by createTime asc, id asc
        limit 1
    </select>
</mapper>
