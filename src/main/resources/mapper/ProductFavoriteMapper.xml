<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.watch.watch_mall.mapper.ProductFavoriteMapper">

    <select id="selectAnyFavoriteByUserIdAndProductId" resultType="com.watch.watch_mall.model.entity.ProductFavorite">
        select
            id,
            userId,
            productId,
            createTime,
            updateTime,
            isDelete
        from product_favorite
        where userId = #{userId}
          and productId = #{productId}
        limit 1
    </select>
</mapper>
